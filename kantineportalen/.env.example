PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/kantineportalen
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
# JWT token-expire styres i MongoDB, ikke via .env.
# Collection: appsettings
# Key: jwt.tokenExpiresInSeconds
# Value: antall sekunder, f.eks. 604800 for 7 dager.
SEED_ADMIN_USERNAME=change-me
SEED_ADMIN_PASSWORD=change-me-long-random-password
# Sett RESET_ADMIN_PASSWORD=true kun når du bevisst vil bytte passordet på eksisterende admin.
# RESET_ADMIN_PASSWORD=false
