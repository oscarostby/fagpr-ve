{
  "name": "kantineportalen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fagprøveprosjekt for kantineportal. React-klient med Vite og Express/MongoDB-backend.",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "node --watch server/server.js",
    "start": "node server/server.js",
    "build": "npm --prefix client run build",
    "preview": "npm --prefix client run preview",
    "lint": "npm --prefix client run lint",
    "test": "node --test \"server/**/*.test.js\"",
    "test:db": "node server/utils/testDatabaseConnection.js",
    "seed": "node server/utils/seed.js",
    "seed:admin": "node server/utils/ensureAdminUser.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.2",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
