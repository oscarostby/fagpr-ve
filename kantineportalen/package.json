{
  "name": "kantineportalen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fagprøveprosjekt for kantineportal. React-klient med Vite og Express/MongoDB-backend.",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "node --watch server/server.js",
    "start": "node server/server.js",
    "build": "npm --prefix client run build",
    "preview": "npm --prefix client run preview",
    "lint": "npm --prefix client run lint",
    "test:db": "node server/utils/testDatabaseConnection.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.2"
  }
}
